#!/bin/bash
# slurmailer: submit a SLURM job and a dependent "notifier" job that emails a
# rich report when the job ends in ANY state (success, fail, timeout, OOM, cancel).
#
# Usage: slurmailer [sbatch-options] <script> [script-args...]
# All arguments pass straight through to sbatch.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=config.sh
source "$HERE/config.sh"
[[ -n "${SLURM_BIN:-}" ]] && export PATH="$SLURM_BIN:$PATH"

if [[ $# -eq 0 ]]; then
  echo "usage: slurmailer [sbatch-options] <script> [script-args...]" >&2
  exit 2
fi
if [[ -z "${EMAIL:-}" ]]; then
  echo "slurmailer: set EMAIL in $HERE/config.sh before use" >&2
  exit 2
fi

mkdir -p "$HERE/logs"

# 1. Submit the real job, passing through every sbatch argument.
if ! JOBID=$(sbatch --parsable "$@"); then
  echo "slurmailer: job submission failed" >&2
  exit 1
fi
JOBID="${JOBID%%;*}"   # --parsable may return "jobid;cluster" on a federation
if [[ -z "$JOBID" ]]; then
  echo "slurmailer: could not parse the submitted job id" >&2
  exit 1
fi
echo "submitted job:  $JOBID"

# 2. Capture fully-resolved paths/metadata while the controller still knows the job.
#    SLURM has already expanded %j/%x in the output paths for us. StdOut/StdErr/WorkDir
#    each occupy their own line, so capture the whole value (handles spaces in paths).
INFO=$(scontrol show job "$JOBID" 2>/dev/null || true)
field() { sed -n "s/^[[:space:]]*$1=\(.*\)$/\1/p" <<<"$INFO" | head -1; }
STDOUT=$(field StdOut)
STDERR=$(field StdErr)
WORKDIR=$(field WorkDir)
SUBMIT_CMD="sbatch $*"

# 3. Submit the dependent notifier job. afterany fires whenever the job terminates.
#    Partition/QOS are added only if configured (empty -> account default).
opts=( --parsable
       --time="$NOTIFIER_TIME" --mem="$NOTIFIER_MEM" --ntasks=1
       --job-name="notify-$JOBID"
       --dependency=afterany:"$JOBID" --kill-on-invalid-dep=yes
       --output="$HERE/logs/notify-%j.out" )
[[ -n "${NOTIFIER_PARTITION:-}" ]] && opts+=( --partition="$NOTIFIER_PARTITION" )
[[ -n "${NOTIFIER_QOS:-}" ]]       && opts+=( --qos="$NOTIFIER_QOS" )
NOTIFIER_JID=$(sbatch "${opts[@]}" \
  "$HERE/notifier.sbatch" \
    --confdir "$HERE" \
    --jobid "$JOBID" \
    --stdout "$STDOUT" \
    --stderr "$STDERR" \
    --workdir "$WORKDIR" \
    --submit "$SUBMIT_CMD")
echo "notifier job:   $NOTIFIER_JID  (emails $EMAIL when $JOBID ends)"
